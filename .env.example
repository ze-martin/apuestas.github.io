# Fuente de datos: github-pages lee reportes HTML publicados; local usa JSON/CSV/localStorage; api consulta VITE_PROTOCOL_API_URL.
VITE_DATA_SOURCE_MODE=github-pages

# Base publica de Vite.
# Para el repo ze-martin/apuestas.github.io usar /apuestas.github.io/.
# Para un repo de usuario llamado ze-martin.github.io usar /.
VITE_BASE_PATH=/apuestas.github.io/

# Indice publico de reportes del Protocolo Apuestas.
VITE_PROTOCOL_INDEX_URL=https://ze-martin.github.io/

# API futura del Protocolo Apuestas. No exponer claves privadas en el frontend.
VITE_PROTOCOL_API_URL=

# API deportiva futura para fixtures, resultados, lesiones, cuotas o mercado.
VITE_SPORTS_API_URL=

# Backend server-side para liquidar resultados reales con API-Football.
# No uses prefijo VITE_ para claves privadas; todo esto se lee solo en server/settlementServer.mjs.
VITE_SETTLEMENT_API_URL=/api/settlements
SETTLEMENT_API_PORT=8787
FOOTBALL_SOURCE=api-football
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=
FOOTBALL_SEASON=2026
API_FOOTBALL_LEAGUES=2,3,39,140,135,78,281,11,13
SETTLEMENT_PENDING_TTL_MINUTES=60
SETTLEMENT_SETTLED_TTL_DAYS=30
SETTLEMENT_TIMEZONE=America/Lima
# Opcional para pruebas o despliegues con reloj distinto. Formato YYYY-MM-DD.
SETTLEMENT_TODAY=

# Persistencia futura. Ejemplos: localStorage, supabase, firebase, postgres-api, custom-api.
VITE_DATABASE_PROVIDER=localStorage

# Autenticacion futura. Ejemplos: none, supabase, auth0, clerk, custom.
VITE_AUTH_PROVIDER=none
VITE_AUTH_ISSUER_URL=
